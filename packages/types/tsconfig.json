{
  "extends": "../typescript-config/base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "composite": true,
    "declaration": true,
    "incremental": true,
    "outDir": "./dist",
    "rootDir": "./",
    "types": ["node"],
    "esModuleInterop": true,
    "paths": {
      "@repo/db/*": ["../db/*"],
      "@repo/db/generated/prisma": ["../db/generated/prisma"]
    }
  },
  "include": ["."],
  "exclude": ["node_modules", "dist"]
}
